{
  "name": "audio-proc-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "sync": "svelte-kit sync",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "backend:dev": "node scripts/run-backend.mjs",
    "build:web": "vite build",
    "preview:web": "vite preview --host 127.0.0.1 --port 4173",
    "check": "npm run sync && svelte-check --tsconfig ./tsconfig.json",
    "build:desktop": "npm run build:web && electron-builder"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.511.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.14.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "svelte": "^5.28.1",
    "svelte-check": "^4.1.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  },
  "build": {
    "appId": "com.leonardodiazvidal.audioprocmvp",
    "productName": "Audio Proc MVP",
    "files": [
      "build/**/*",
      "electron/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
